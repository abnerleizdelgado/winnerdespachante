{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "winnerdespachante",
  "compatibility_date": "2026-07-02",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "winnerdespachante.com.br", "custom_domain": true },
    { "pattern": "www.winnerdespachante.com.br", "custom_domain": true }
  ]
}